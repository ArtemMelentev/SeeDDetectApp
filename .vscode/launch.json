{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "SeedDetect (One Click)",
      "request": "launch",
      "type": "node-terminal",
      "preLaunchTask": "Start SeedDetect emulator",
      "command": "$env:ANDROID_HOME='C:\\Android\\Sdk'; $env:ANDROID_SDK_ROOT='C:\\Android\\Sdk'; $env:JAVA_HOME='C:\\Program Files\\Eclipse Adoptium\\jdk-17.0.18.8-hotspot'; & 'C:\\Users\\Artem Melentyev\\source\\flutter\\bin\\flutter.bat' run -d emulator-5554 --device-timeout 120"
    },
    {
      "name": "SeedDetect (Dart Extension)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "debug",
      "program": "lib/main.dart",
      "deviceId": "emulator-5554",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "Start SeedDetect emulator",
      "env": {
        "ANDROID_HOME": "C:\\Android\\Sdk",
        "ANDROID_SDK_ROOT": "C:\\Android\\Sdk",
        "JAVA_HOME": "C:\\Program Files\\Eclipse Adoptium\\jdk-17.0.18.8-hotspot"
      }
    }
  ]
}
